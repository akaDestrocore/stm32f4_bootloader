{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Boot",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/target/thumbv7em-none-eabihf/debug/boot",
            "servertype": "stlink",
            "device": "STM32F407VGTx",
            "interface": "swd",
            "runToEntryPoint": "main",
            "svdFile": "${config:STM32VSCodeExtension.cubeCLT.path}/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "v1": false,
            "serverpath": "${config:STM32VSCodeExtension.cubeCLT.path}/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "stm32cubeprogrammer": "${config:STM32VSCodeExtension.cubeCLT.path}/STM32CubeProgrammer/bin",
            "stlinkPath": "${config:STM32VSCodeExtension.cubeCLT.path}/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "armToolchainPath": "${config:STM32VSCodeExtension.cubeCLT.path}/GNU-tools-for-STM32/bin",
            "gdbPath": "${config:STM32VSCodeExtension.cubeCLT.path}/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
            "serverArgs": ["-m", "0"],
            "preLaunchTask": "Build Boot"
        },
        {
            "name": "Debug Loader (Alternative)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/target/thumbv7em-none-eabihf/debug/loader",
            "servertype": "stlink",
            "device": "STM32F407VGTx",
            "interface": "swd",
            "svdFile": "c:\\st\\stm32cubeclt_1.16.0/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "v1": false,
            "serverpath": "c:\\st\\stm32cubeclt_1.16.0/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "stm32cubeprogrammer": "c:\\st\\stm32cubeclt_1.16.0/STM32CubeProgrammer/bin",
            "stlinkPath": "c:\\st\\stm32cubeclt_1.16.0/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "armToolchainPath": "c:\\st\\stm32cubeclt_1.16.0/GNU-tools-for-STM32/bin",
            "gdbPath": "c:\\st\\stm32cubeclt_1.16.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
            "serverArgs": ["-m", "0"],
            "showDevDebugOutput": "parsed",
            "preLaunchCommands": [
                "monitor reset",
                "monitor halt",
                "set {unsigned int}0xE000ED08 = 0x08004000",
                "set $pc = 0x08004005",
                "set $sp = *(unsigned int*)0x08004000",
                "set var $r0 = 0",
                "set var $r1 = 0",
                "set var $r2 = 0",
                "set var $r3 = 0",
                "break main",
                "continue"
            ],
            "preLaunchTask": "Build Loader"
        },
        {
            "name": "Debug Updater",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/target/thumbv7em-none-eabihf/debug/updater",
            "servertype": "stlink",
            "device": "STM32F407VGTx",
            "interface": "swd",
            "runToEntryPoint": "main",
            "svdFile": "${config:STM32VSCodeExtension.cubeCLT.path}/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "v1": false,
            "serverpath": "${config:STM32VSCodeExtension.cubeCLT.path}/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "stm32cubeprogrammer": "${config:STM32VSCodeExtension.cubeCLT.path}/STM32CubeProgrammer/bin",
            "stlinkPath": "${config:STM32VSCodeExtension.cubeCLT.path}/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "armToolchainPath": "${config:STM32VSCodeExtension.cubeCLT.path}/GNU-tools-for-STM32/bin",
            "gdbPath": "${config:STM32VSCodeExtension.cubeCLT.path}/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
            "serverArgs": ["-m", "0"],
            "preLaunchCommands": [
                "set $pc = 0x08008004"
            ],
            "preLaunchTask": "Build Updater"
        },
        {
            "name": "Debug Application",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/target/thumbv7em-none-eabihf/debug/application",
            "servertype": "stlink",
            "device": "STM32F407VGTx",
            "interface": "swd",
            "runToEntryPoint": "main",
            "svdFile": "${config:STM32VSCodeExtension.cubeCLT.path}/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "v1": false,
            "serverpath": "${config:STM32VSCodeExtension.cubeCLT.path}/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "stm32cubeprogrammer": "${config:STM32VSCodeExtension.cubeCLT.path}/STM32CubeProgrammer/bin",
            "stlinkPath": "${config:STM32VSCodeExtension.cubeCLT.path}/STLink-gdb-server/bin/ST-LINK_gdbserver",
            "armToolchainPath": "${config:STM32VSCodeExtension.cubeCLT.path}/GNU-tools-for-STM32/bin",
            "gdbPath": "${config:STM32VSCodeExtension.cubeCLT.path}/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
            "serverArgs": ["-m", "0"],
            "preLaunchCommands": [
                "set $pc = 0x08020004"
            ],
            "preLaunchTask": "Build Application"
        }
    ]
}